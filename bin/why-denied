#!/bin/sh
#
# why-denied — CLI for the LD_PRELOAD permission-denied diagnostic shim.
#
# POSIX sh only. Override paths for development / tests:
#   WHY_DENIED_SO       — path to why-denied.so (default: /usr/lib/why-denied/why-denied.so)
#   WHY_DENIED_CLI_ROOT — prefix for /etc (default: empty → system /etc)

set -eu

SO_DEFAULT=/usr/lib/why-denied/why-denied.so
SO="${WHY_DENIED_SO:-$SO_DEFAULT}"
CLI_ROOT="${WHY_DENIED_CLI_ROOT:-}"
ETC="${CLI_ROOT}/etc"
SERVICE_DROPIN="${ETC}/systemd/system.conf.d/why-denied.conf"
SERVICE_MODE="${ETC}/why-denied/service-mode"
CLI="${WHY_DENIED_CLI:-/usr/bin/why-denied}"

die() {
    printf 'why-denied: %s\n' "$*" >&2
    exit 1
}

need_root() {
    # WHY_DENIED_CLI_ROOT redirects /etc writes for tests; skip the root check.
    if [ -n "$CLI_ROOT" ]; then
        return 0
    fi
    if [ "$(id -u)" -ne 0 ]; then
        die "this operation requires root (sudo)"
    fi
}

so_installed() {
    [ -e "$SO" ]
}

# Append our .so to LD_PRELOAD idempotently; result in LD_PRELOAD.
preload_ld() {
    case ":${LD_PRELOAD:-}:" in
        *:"$SO":*) ;;
        *)
            if [ -n "${LD_PRELOAD:-}" ]; then
                LD_PRELOAD="${LD_PRELOAD}:$SO"
            else
                LD_PRELOAD="$SO"
            fi
            ;;
    esac
    export LD_PRELOAD
}

# Strip our .so from LD_PRELOAD; unset when empty.
strip_preload() {
    if [ -z "${LD_PRELOAD:-}" ]; then
        return 0
    fi
    new=""
    old_ifs=$IFS
    IFS=:
    for entry in $LD_PRELOAD; do
        [ -n "$entry" ] || continue
        [ "$entry" = "$SO" ] && continue
        if [ -n "$new" ]; then
            new="$new:$entry"
        else
            new="$entry"
        fi
    done
    IFS=$old_ifs
    if [ -n "$new" ]; then
        LD_PRELOAD="$new"
        export LD_PRELOAD
    else
        unset LD_PRELOAD || true
    fi
}

preload_in_env() {
    case ":${LD_PRELOAD:-}:" in
        *:"$SO":*) printf 'yes' ;;
        *) printf 'no' ;;
    esac
}

cmd_status() {
    printf 'Library:     %s' "$SO"
    if so_installed; then
        printf ' (installed)\n'
    else
        printf ' (not found — try: make && sudo make install)\n'
    fi

    if [ "$(preload_in_env)" = yes ]; then
        printf 'This shell:  active — child commands will use why-denied\n'
    else
        printf 'This shell:  inactive — try: eval "$(why-denied enable session)"\n'
    fi

    if [ -t 2 ]; then
        printf 'TTY:         yes (stderr is a terminal)\n'
    else
        printf 'TTY:         no (stderr is not a terminal)\n'
    fi

    if [ -n "${WHY_DENIED_ENABLE:-}" ]; then
        printf 'Non-TTY:     WHY_DENIED_ENABLE is set → diagnostics enabled without TTY\n'
    elif [ -f "$SERVICE_MODE" ]; then
        printf 'Non-TTY:     global service-mode marker present → diagnostics enabled without TTY\n'
    else
        printf 'Non-TTY:     disabled (set WHY_DENIED_ENABLE=1 or enable global/service scope)\n'
    fi

    if [ -f "$SERVICE_DROPIN" ]; then
        printf 'Systemd:     instrumentation ON — restarted units preload why-denied and may emit [why-denied] lines to journald\n'
        printf '             (%s)\n' "$SERVICE_DROPIN"
    else
        printf 'Systemd:     instrumentation OFF (no manager drop-in; use: sudo why-denied enable service)\n'
    fi

    if [ -f "$SERVICE_MODE" ]; then
        printf 'Global:      non-TTY diagnostics ON when preloaded (%s)\n' "$SERVICE_MODE"
    else
        printf 'Global:      non-TTY diagnostics OFF (use: sudo why-denied enable global)\n'
    fi

    if [ -n "${WHY_DENIED_DISABLE:-}" ]; then
        printf 'Overrides:   WHY_DENIED_DISABLE is set → shim forced silent\n'
    else
        printf 'Overrides:   WHY_DENIED_DISABLE unset\n'
    fi
}

cmd_run() {
    if [ "$#" -eq 0 ]; then
        die "run: missing command (usage: why-denied run [--] <cmd…>)"
    fi
    if [ "$1" = -- ]; then
        shift
    fi
    if [ "$#" -eq 0 ]; then
        die "run: missing command after --"
    fi
    if ! so_installed; then
        die "shared library not found at $SO"
    fi
    preload_ld
    if [ -z "${WHY_DENIED_DISABLE:-}" ]; then
        export WHY_DENIED_ENABLE=1
    fi
    exec "$@"
}

cmd_try() {
    if [ "$#" -ne 1 ]; then
        die "try: usage: why-denied try <path>"
    fi
    cmd_run cat -- "$1"
}

cmd_shell() {
    if ! so_installed; then
        die "shared library not found at $SO"
    fi
    preload_ld
    if [ -z "${WHY_DENIED_DISABLE:-}" ]; then
        export WHY_DENIED_ENABLE=1
    fi
    export WHY_DENIED_REEXEC=1

    if [ -n "${BASH:-}" ]; then
        exec "$BASH" -l
    fi
    if [ -n "${ZSH_NAME:-}" ]; then
        exec "$ZSH_NAME" -l
    fi
    if [ -n "${SHELL:-}" ] && [ -x "$SHELL" ]; then
        exec "$SHELL" -l
    fi
    exec /bin/sh -l
}

session_enable_print() {
    if ! so_installed; then
        die "shared library not found at $SO"
    fi
    preload_ld
    printf 'export LD_PRELOAD=%s\n' "$LD_PRELOAD"
    printf 'export WHY_DENIED_ENABLE=1\n'
    printf 'unset WHY_DENIED_DISABLE\n'
}

session_disable_print() {
    strip_preload
    if [ -n "${LD_PRELOAD:-}" ]; then
        printf 'export LD_PRELOAD=%s\n' "$LD_PRELOAD"
    else
        printf 'unset LD_PRELOAD\n'
    fi
    printf 'unset WHY_DENIED_ENABLE\n'
}

print_examples_full() {
    cat <<'EOF'
Examples:
  # See what's active in this shell and system-wide
  why-denied status

  # Explain a "Permission denied" in one shot (no setup needed)
  why-denied try /etc/shadow
  why-denied run cat ./secret.txt

  # Run a script or binary once under why-denied
  why-denied run -- ./deploy.sh

  # Turn on why-denied for your current shell
  eval "$(why-denied enable session)"

  # Debug a systemd unit — extra [why-denied] lines land in journalctl
  # (does not start why-denied as its own background service)
  sudo why-denied enable service
  sudo systemctl daemon-reload
  sudo systemctl restart nginx.service
  journalctl -u nginx.service -f

  # Silence why-denied for a single command
  WHY_DENIED_DISABLE=1 why-denied run cat foo

  # Turn off systemd instrumentation when you're done troubleshooting
  sudo why-denied disable service
  sudo systemctl daemon-reload
EOF
}

print_enable_scopes_notice() {
    cat >&2 <<'EOF'
You ran 'why-denied enable' without picking a scope — defaulting to 'session'
(just this shell). Choose a scope explicitly next time:

  session   Wire up your current shell. Cron and systemd stay as they are.
  service   After restart, systemd units can log [why-denied] hints to journalctl
            when they hit "Permission denied". Does not run why-denied as its
            own background service.
  global    Let cron, pipes, and journald show [why-denied] when LD_PRELOAD is
            already set (pairs well with 'service' or cron).

Examples:
  # Your shell only
  eval "$(why-denied enable session)"

  # A unit that keeps failing with "Permission denied"
  sudo why-denied enable service
  sudo systemctl daemon-reload
  sudo systemctl restart myapp.service
  journalctl -u myapp.service -f

  # Cron / non-interactive jobs (with LD_PRELOAD already set)
  sudo why-denied enable global
EOF
}

write_service_dropin() {
    need_root
    install -d "$(dirname "$SERVICE_DROPIN")"
    cat >"$SERVICE_DROPIN" <<EOF
# Managed by why-denied. Disable with: why-denied disable service
# Instruments systemd units — does NOT run why-denied as a background service.
[Manager]
DefaultEnvironment=LD_PRELOAD=$SO_DEFAULT
DefaultEnvironment=WHY_DENIED_ENABLE=1
EOF
    chmod 0644 "$SERVICE_DROPIN"
    cat >&2 <<EOF
Done — systemd units can now log [why-denied] hints to journalctl.

This does not start why-denied as its own background service. Nothing changes
until you reload systemd and restart the units you care about. After restart,
permission-denied failures may include an extra [why-denied] line explaining why.

Examples:
  sudo systemctl daemon-reload
  sudo systemctl restart nginx.service
  journalctl -u nginx.service -f

Wrote ${SERVICE_DROPIN}

When you're finished troubleshooting:
  sudo why-denied disable service && sudo systemctl daemon-reload
EOF
}

remove_service_dropin() {
    need_root
    if [ -f "$SERVICE_DROPIN" ]; then
        rm -f "$SERVICE_DROPIN"
        cat >&2 <<EOF
Systemd instrumentation is off — new units will not pick up why-denied from this
drop-in. Units that are already running keep their current environment until
restarted.

Removed ${SERVICE_DROPIN}

Example:
  sudo systemctl daemon-reload
EOF
    else
        printf 'Nothing to do — systemd instrumentation is already off.\n' >&2
    fi
}

enable_global() {
    need_root
    install -d "$(dirname "$SERVICE_MODE")"
    : >"$SERVICE_MODE"
    chmod 0644 "$SERVICE_MODE"
    cat >&2 <<EOF
Global non-TTY diagnostics are on (${SERVICE_MODE}).

This marker does not preload why-denied by itself — it only allows [why-denied]
output when LD_PRELOAD is already set (for example via 'enable service' or
cron). Handy for journald, cron mail, and piped stderr.

Example:
  sudo why-denied disable global
EOF
}

disable_global() {
    need_root
    if [ -f "$SERVICE_MODE" ]; then
        rm -f "$SERVICE_MODE"
        printf 'Global non-TTY diagnostics are off.\n' >&2
    else
        printf 'Nothing to do — global non-TTY diagnostics are already off.\n' >&2
    fi
}

cmd_enable() {
    if [ "$#" -eq 0 ]; then
        print_enable_scopes_notice
        scope=session
    else
        scope="$1"
    fi
    case "$scope" in
        session)
            session_enable_print
            if [ "$#" -eq 0 ]; then
                printf '\nApplying session scope. To load these exports:\n' >&2
            else
                printf 'Session scope ready. To load these exports:\n' >&2
            fi
            printf '  eval "$(why-denied enable session)"\n' >&2
            ;;
        service) write_service_dropin ;;
        global) enable_global ;;
        *) die "unknown scope '$scope' (expected: session, service, global; try: why-denied enable)" ;;
    esac
}

cmd_disable() {
    scope="${1:-session}"
    case "$scope" in
        session)
            session_disable_print
            printf 'To apply in your shell:\n' >&2
            printf '  eval "$(why-denied disable session)"\n' >&2
            ;;
        service) remove_service_dropin ;;
        global) disable_global ;;
        *) die "unknown scope '$scope' (expected: session, service, global)" ;;
    esac
}

cmd_help() {
    cat <<'EOF'
why-denied — friendly answers when Linux says "Permission denied"

When a command fails with EACCES/EPERM, why-denied prints what went wrong and
often the exact chmod/getfacl fix. Use this CLI to try it once, check your
setup, or widen diagnostics to systemd logs.

Usage:
  why-denied <command> [arguments]

Available Commands:
  status    Show whether why-denied is active here and system-wide
  run       Run any command with why-denied loaded
  try       Quick test: read a path and show the diagnosis
  shell     Open a login shell with why-denied already loaded
  enable    Turn diagnostics on (scope: session, service, global)
  disable   Turn diagnostics off
  help      Show this help (-h, --help)

Enable scopes (for enable / disable):
  session   Your shell only (default). Prints exports for eval.
  service   Restarted systemd units may log [why-denied] to journalctl.
            Does not run why-denied as its own background service.
  global    Non-TTY output when LD_PRELOAD is already set (cron, pipes).

EOF
    print_examples_full
    cat <<'EOF'

Environment variables:
  WHY_DENIED_SO            Override path to why-denied.so
  WHY_DENIED_ENABLE=1      Diagnose even without a terminal
  WHY_DENIED_DISABLE=1     Stay quiet (overrides enable)

Run 'man why-denied' for the full manual.
EOF
}

main() {
    if [ "$#" -eq 0 ]; then
        cmd_help
        exit 0
    fi
    cmd="$1"
    shift
    case "$cmd" in
        status) cmd_status "$@" ;;
        run) cmd_run "$@" ;;
        try) cmd_try "$@" ;;
        shell) cmd_shell "$@" ;;
        enable) cmd_enable "$@" ;;
        disable) cmd_disable "$@" ;;
        help | -h | --help) cmd_help ;;
        *)
            printf 'why-denied: unknown command '\''%s'\''\n\n' "$cmd" >&2
            cat >&2 <<'EOF'
Try one of these:
  why-denied status
  why-denied try /path/to/file
  why-denied help
EOF
            exit 1
            ;;
    esac
}

main "$@"
